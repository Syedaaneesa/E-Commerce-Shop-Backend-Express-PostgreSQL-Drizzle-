{
  "name": "api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "lib/*"
  ],
  "scripts": {
    "dev": "NODE_ENV=development npm run build && npm run start",
    "build": "node ./build.mjs",
    "start": "node --env-file-if-exists=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:push": "npm run push --workspace=@workspace/db",
    "db:push-force": "npm run push-force --workspace=@workspace/db"
  },
  "dependencies": {
    "@clerk/express": "^2.1.37",
    "@clerk/shared": "^4.25.0",
    "@workspace/api-zod": "*",
    "@workspace/db": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.4",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.0",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "^3.1.0",
    "typescript": "^5.9.2"
  }
}
